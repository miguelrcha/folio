# Copy this file to `.env.local` and fill in the values. Never commit `.env.local`.
# All values below are placeholders — get the real ones from the Supabase project.

# Supabase project URL and public (anon) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Bypasses Row Level Security; never expose it to
# the client. Used by the batch cron sync (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte base64 key used to encrypt the stored GitHub access token
# (lib/crypto.ts). Generate one with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=your-32-byte-base64-key

# Shared secret guarding the daily cron endpoint (/api/cron/sync-all). Vercel
# sends it as an `Authorization: Bearer <CRON_SECRET>` header.
CRON_SECRET=your-cron-secret

# Note: GitHub OAuth is configured inside Supabase (Auth > Providers > GitHub),
# not through env vars here.
